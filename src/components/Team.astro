---
import Section from "./ui/Section.astro";
import { getCollection } from "astro:content";

const members = (await getCollection("team")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Section id="equipo" eyebrow="Quiénes te guían" title="Equipo">
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {
      members.map((member) => (
        <article class="overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900">
          <div class="relative aspect-[3/4] overflow-hidden bg-gradient-to-b from-zinc-800 to-black">
            {member.data.image ? (
              <img
                src={member.data.image}
                alt={member.data.name}
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center">
                <span class="font-display text-8xl uppercase text-zinc-700">
                  {member.data.name.charAt(0)}
                </span>
              </div>
            )}
          </div>
          <div class="p-5">
            <h3 class="font-display text-2xl uppercase tracking-wide text-white">
              {member.data.name}
            </h3>
            <p class="font-data text-lg uppercase tracking-wide text-amber-400">
              {member.data.role}
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {member.data.specialties.map((specialty) => (
                <li class="rounded-full border border-zinc-700 px-3 py-1 font-body text-xs text-zinc-400">
                  {specialty}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))
    }
  </div>
</Section>
