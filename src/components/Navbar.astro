---
import { navItems } from "../data/navigation";
import { site } from "../data/site";
---

<header
  class="sticky top-0 z-50 border-b border-zinc-800 bg-black/90 backdrop-blur"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3"
  >
    <a href="#inicio" class="flex items-center gap-2">
      <img src="/logo.jpg" alt={site.name} class="h-10 w-10 rounded" />
      <span class="font-display text-xl uppercase tracking-wider text-white">
        Olimpo<span class="text-amber-400">Box</span>
      </span>
    </a>

    <!-- Desktop navigation -->
    <ul class="hidden items-center gap-6 xl:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="font-data text-lg uppercase tracking-wide text-zinc-300 transition hover:text-amber-400"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      class="text-amber-400 xl:hidden"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="h-8 w-8"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <ul
    id="mobile-menu"
    class="hidden flex-col gap-1 border-t border-zinc-800 px-6 py-4 xl:hidden"
  >
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            data-nav-link
            class="block py-2 font-data text-xl uppercase tracking-wide text-zinc-300 transition hover:text-amber-400"
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const isOpen: boolean = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
  });

  // Close the menu after tapping a link.
  menu?.querySelectorAll("[data-nav-link]").forEach((link) => {
    link.addEventListener("click", () => menu?.classList.add("hidden"));
  });
</script>
