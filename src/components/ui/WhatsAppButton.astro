---
import { buildWhatsAppUrl } from "../../utils/whatsapp";

/**
 * Primary conversion atom. Wraps the WhatsApp deep-link so the whole site
 * converts through a single, consistent component.
 *
 * Variants (Open/Closed: extend without modifying):
 *   - primary: amber button on dark backgrounds (default)
 *   - dark:    black button for use on amber backgrounds
 */
interface Props {
  message?: string;
  label?: string;
  variant?: "primary" | "dark";
  class?: string;
}

const {
  message,
  label = "Escríbenos por WhatsApp",
  variant = "primary",
  class: className = "",
}: Props = Astro.props;

const href: string = buildWhatsAppUrl(message);

const base: string =
  "inline-flex items-center justify-center gap-2 rounded-full px-7 py-3 font-data text-xl font-semibold uppercase tracking-wide transition";

const variants: Record<NonNullable<Props["variant"]>, string> = {
  primary: "bg-amber-400 text-black hover:bg-amber-300",
  dark: "bg-black text-amber-400 hover:bg-zinc-900",
};
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[base, variants[variant], className]}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="h-5 w-5"
    aria-hidden="true"
  >
    <path
      d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2Zm5.8 14.01c-.24.68-1.4 1.3-1.94 1.34-.5.05-1.13.24-3.66-.77-3.07-1.24-5.04-4.37-5.2-4.58-.15-.2-1.24-1.65-1.24-3.15 0-1.5.79-2.24 1.07-2.54.28-.3.61-.38.81-.38l.58.01c.19.01.44-.07.69.53.24.6.83 2.07.9 2.22.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.17-.31.39-.44.52-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.02 1.12.99 2.06 1.3 2.36 1.45.3.15.47.13.64-.08.17-.2.74-.86.94-1.16.2-.3.39-.25.66-.15.27.1 1.7.8 1.99.95.29.15.48.22.55.34.07.13.07.73-.17 1.42Z"
    ></path>
  </svg>
  {label}
</a>
