---
import Section from "./ui/Section.astro";
import { events } from "../data/events";
---

<Section id="eventos" eyebrow="Comunidad en acción" title="Eventos" alt>
  <div class="grid gap-6 md:grid-cols-2">
    {
      events.map((event) => (
        <article class="flex flex-col overflow-hidden rounded-2xl border border-zinc-800 bg-black">
          <img
            src={event.image}
            alt={event.title}
            loading="lazy"
            class="aspect-video w-full object-cover"
          />
          <div class="flex flex-col gap-3 p-6">
            <span class="self-start rounded-full bg-amber-400 px-3 py-1 font-data text-sm font-semibold uppercase tracking-wide text-black">
              {event.tag}
            </span>
            <h3 class="font-display text-2xl uppercase tracking-wide text-white">
              {event.title}
            </h3>
            <p class="font-body text-zinc-400">{event.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</Section>
