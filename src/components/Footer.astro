---
import { site } from "../data/site";
import { navItems } from "../data/navigation";
import SocialLinks from "./ui/SocialLinks.astro";

const currentYear: number = new Date().getFullYear();
---

<footer class="border-t border-zinc-800 bg-black">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-12 md:flex-row md:items-start md:justify-between"
  >
    <div class="flex flex-col gap-3">
      <a href="#inicio" class="flex items-center gap-2">
        <img src="/logo.jpg" alt={site.name} class="h-12 w-12 rounded" />
        <span class="font-display text-2xl uppercase tracking-wider text-white">
          Olimpo<span class="text-amber-400">Box</span>
        </span>
      </a>
      <p class="font-data text-lg uppercase tracking-wide text-zinc-500">
        {site.tagline}
      </p>
      <SocialLinks class="mt-2" />
    </div>

    <nav>
      <ul class="grid grid-cols-2 gap-x-10 gap-y-2 sm:grid-cols-3">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="font-body text-sm text-zinc-400 transition hover:text-amber-400"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="border-t border-zinc-900 py-5 text-center">
    <p class="font-body text-xs text-zinc-600">
      © {currentYear} {site.name}. Villavicencio, Colombia. Forjando dioses.
    </p>
  </div>
</footer>
