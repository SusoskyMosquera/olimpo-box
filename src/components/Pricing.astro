---
import Section from "./ui/Section.astro";
import WhatsAppButton from "./ui/WhatsAppButton.astro";
import { plans } from "../data/pricing";
import { formatThousands } from "../utils/format";
---

<Section id="planes" eyebrow="Tarifas 2026" title="Planes" alt>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      plans.map((plan) => (
        <article
          class:list={[
            "flex flex-col gap-5 rounded-2xl border bg-black p-6",
            plan.featured
              ? "border-amber-400 ring-1 ring-amber-400"
              : "border-zinc-800",
          ]}
        >
          {plan.featured && (
            <span class="self-start rounded-full bg-amber-400 px-3 py-1 font-data text-sm font-semibold uppercase tracking-wide text-black">
              Destacada
            </span>
          )}

          <header>
            <h3 class="font-display text-2xl uppercase tracking-wide text-white">
              {plan.name}
            </h3>
            <p class="mt-2 font-data text-5xl font-semibold text-amber-400">
              ${formatThousands(plan.amount)}
            </p>
            <p class="font-data text-lg uppercase tracking-wide text-zinc-400">
              {plan.unit}
            </p>
          </header>

          <ul class="flex flex-1 flex-col gap-2">
            {plan.perks.map((perk) => (
              <li class="flex items-start gap-2 font-body text-sm text-zinc-300">
                <span class="mt-1 text-amber-400">✓</span>
                {perk}
              </li>
            ))}
          </ul>

          <WhatsAppButton
            message={`Hola Olimpo Box, me interesa el plan ${plan.name} 💪`}
            label="Lo quiero"
            class="w-full text-lg"
          />
        </article>
      ))
    }
  </div>
</Section>
