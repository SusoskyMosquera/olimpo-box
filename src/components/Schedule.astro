---
import Section from "./ui/Section.astro";
import { schedule } from "../data/schedule";
---

<Section id="horarios" eyebrow="Cuándo entrenas" title="Horarios">
  <div class="grid gap-6 md:grid-cols-2">
    {
      schedule.map((day) => (
        <article class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
          <h3 class="font-display text-2xl uppercase tracking-wide text-amber-400">
            {day.label}
          </h3>
          <div class="mt-4 flex flex-col gap-5">
            {day.groups.map((group) => (
              <div>
                <p class="font-data text-lg uppercase tracking-widest text-zinc-500">
                  {group.period}
                </p>
                <ul class="mt-2 flex flex-wrap gap-2">
                  {group.blocks.map((block) => (
                    <li class="rounded-lg border border-zinc-700 bg-black px-3 py-1 font-data text-xl tracking-wide text-white">
                      {block.start} - {block.end}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</Section>
