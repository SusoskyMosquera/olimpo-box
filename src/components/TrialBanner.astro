---
import WhatsAppButton from "./ui/WhatsAppButton.astro";
import { site } from "../data/site";
---

<section id="cortesia" class="scroll-mt-20 bg-amber-400">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 py-14 text-center md:flex-row md:justify-between md:text-left"
  >
    <div>
      <p class="font-data text-xl font-semibold uppercase tracking-widest text-black/70">
        Sin compromiso
      </p>
      <h2
        class="font-display text-4xl uppercase leading-none tracking-wider text-black md:text-5xl"
      >
        Tu primera clase es de cortesía
      </h2>
      <p class="mt-2 font-body text-black/80">
        Ven, entrena con nosotros y siente la energía del box antes de decidir.
      </p>
    </div>

    <WhatsAppButton
      message={site.freeTrial.message}
      label="Reservar ahora"
      variant="dark"
      class="shrink-0 text-2xl"
    />
  </div>
</section>
