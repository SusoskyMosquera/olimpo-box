---
import { site } from "../data/site";
import WhatsAppButton from "./ui/WhatsAppButton.astro";

const heroImage: string | undefined = "/images/hero.jpg";
---

<section
  id="inicio"
  class="relative flex min-h-[90vh] scroll-mt-20 items-center justify-center overflow-hidden bg-black"
>
  <!-- Background: photo with dark overlay, or gradient fallback -->
  {
    heroImage ? (
      <Fragment>
        <img
          src={heroImage}
          alt=""
          class="pointer-events-none absolute inset-0 h-full w-full object-cover"
        />
        <div class="pointer-events-none absolute inset-0 bg-black/80" />
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black via-black/40 to-black/60" />
      </Fragment>
    ) : (
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-zinc-900 via-black to-black" />
    )
  }

  <div
    class="relative z-10 mx-auto flex max-w-3xl flex-col items-center gap-7 px-6 text-center"
  >
    <div
      class="flex h-36 w-36 items-center justify-center rounded-full bg-black ring-2 ring-amber-400/40 md:h-44 md:w-44"
    >
      <img
        src="/logo.jpg"
        alt={site.name}
        class="h-[72%] w-[72%] object-contain"
      />
    </div>

    <h1
      class="font-display text-5xl uppercase leading-none tracking-wider text-white md:text-7xl"
    >
      Forja tu cuerpo<br />
      <span class="text-amber-400">como un dios del Olimpo</span>
    </h1>

    <p class="font-body max-w-xl text-lg text-zinc-300">
      {site.tagline} en Villavicencio.
    </p>

    <div class="mt-1 flex flex-col items-center gap-4 sm:flex-row">
      <WhatsAppButton
        message={site.freeTrial.message}
        label="Reserva tu clase gratis"
      />
      <a
        href="#planes"
        class="font-data text-xl uppercase tracking-wide text-zinc-300 underline-offset-4 transition hover:text-amber-400 hover:underline"
      >
        Ver planes
      </a>
    </div>
  </div>
</section>
