---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import { site } from "../data/site";
---

<Section id="ubicacion" eyebrow="Dónde estamos" title="Ubicación">
  <div class="grid items-stretch gap-8 lg:grid-cols-2">
    <div
      class="flex flex-col justify-center gap-6 rounded-2xl border border-zinc-800 bg-zinc-900 p-8"
    >
      <span class="text-amber-400">
        <Icon name="pin" class="h-12 w-12" />
      </span>

      <div>
        <p class="font-display text-3xl uppercase tracking-wide text-white">
          {site.location.city}
        </p>
        <p class="mt-2 font-body text-lg text-zinc-300">
          {site.location.address}
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href={site.location.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-amber-400 px-7 py-3 font-data text-xl uppercase tracking-wide text-black transition hover:bg-amber-300"
        >
          Cómo llegar
        </a>
        <a
          href="#horarios"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-amber-400 px-7 py-3 font-data text-xl uppercase tracking-wide text-amber-400 transition hover:bg-amber-400 hover:text-black"
        >
          Ver horarios
        </a>
      </div>
    </div>

    <img
      src="/images/services/open-box.png"
      alt="Sede de Olimpo Box en Villavicencio"
      class="aspect-[4/3] w-full rounded-2xl object-cover lg:aspect-auto lg:h-full"
    />
  </div>
</Section>
