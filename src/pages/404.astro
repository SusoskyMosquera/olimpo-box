---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Página no encontrada — Olimpo Box">
  <main
    class="flex min-h-screen flex-col items-center justify-center gap-6 px-6 text-center"
  >
    <p class="font-display text-8xl leading-none text-amber-400">404</p>
    <h1
      class="font-display text-4xl uppercase tracking-wider text-white md:text-5xl"
    >
      Página no encontrada
    </h1>
    <p class="font-body max-w-md text-zinc-400">
      Esta página se fue de WOD. Volvamos al inicio y sigamos entrenando.
    </p>
    <a
      href="/"
      class="rounded-full bg-amber-400 px-7 py-3 font-data text-xl uppercase tracking-wide text-black transition hover:bg-amber-300"
    >
      Volver al inicio
    </a>
  </main>
</Layout>
